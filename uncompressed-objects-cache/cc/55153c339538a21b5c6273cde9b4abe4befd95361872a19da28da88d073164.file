  </component><component type="desktop-application">
    <id>io.github.calstfrancis.rubric</id>
    <name>Rubric</name>
    <summary>Worship service planning with RCL integration</summary>
    <project_license>GPL-3.0-or-later</project_license>
    <description>
      <p>
      Rubric is a GNOME-native worship service planning tool for United Church
      of Canada ministry. Plan service orders, look up RCL readings, find
      hymns, fetch Bible passages, and export polished bulletins — HTML or
      PDF. PDF export uses the bundled Typst typesetter; no LaTeX required.
    </p>
      <p>Features include:</p>
      <ul>
        <li>Revised Common Lectionary readings, liturgical colour, and per-Proper hymn suggestions</li>
        <li>Hymn lookup from Voices United, More Voices, and Let Us Sing via Hymnary.org</li>
        <li>Bible passage viewer (WEB, KJV, ASV, ESV) with one-click scripture insertion</li>
        <li>Rich text and raw Typst editing per service element</li>
        <li>Live PDF bulletin preview with bundled Typst compiler</li>
        <li>HTML bulletin export — print to PDF directly from your browser</li>
        <li>Service Planner to browse and open all your saved services</li>
        <li>GitHub sync to back up and share services across machines</li>
        <li>Snippets library and responsive reading builder</li>
        <li>Named service order templates</li>
      </ul>
    </description>
    <developer>
      <name>Caleb St. Francis</name>
    </developer>
    <developer_name>Caleb St. Francis</developer_name>
    <requires>
      <display_length>600</display_length>
    </requires>
    <recommends>
      <display_length>768</display_length>
    </recommends>
    <launchable type="desktop-id">io.github.calstfrancis.rubric.desktop</launchable>
    <icon type="cached" width="48" height="48">io.github.calstfrancis.rubric.png</icon>
    <icon type="cached" width="64" height="64">io.github.calstfrancis.rubric.png</icon>
    <icon type="cached" width="64" height="64" scale="2">io.github.calstfrancis.rubric.png</icon>
    <icon type="cached" width="128" height="128">io.github.calstfrancis.rubric.png</icon>
    <icon type="cached" width="128" height="128" scale="2">io.github.calstfrancis.rubric.png</icon>
    <icon type="stock">io.github.calstfrancis.rubric</icon>
    <url type="homepage">https://github.com/calstfrancis/rubric</url>
    <url type="bugtracker">https://github.com/calstfrancis/rubric/issues</url>
    <categories>
      <category>Office</category>
      <category>Education</category>
    </categories>
    <provides>
      <mediatype>application/x-liturgy</mediatype>
    </provides>
    <keywords>
      <keyword>worship</keyword>
      <keyword>liturgy</keyword>
      <keyword>service</keyword>
      <keyword>church</keyword>
      <keyword>UCC</keyword>
      <keyword>lectionary</keyword>
      <keyword>RCL</keyword>
    </keywords>
    <releases>
      <release type="stable" version="0.15.0" timestamp="1780790400">
        <description>
          <p>Phase 4 — Polish and Packaging. Typst syntax highlighting in the element editor (GtkSourceView). Structured error parsing for compilation failures. In-app Typst template editor in Preferences → Typst Files with Reset to default. Bundled typst binary included in deb and rpm packages. Documentation updated throughout.</p>
        </description>
      </release>
      <release type="stable" version="0.14.8" timestamp="1780704000">
        <description>
          <p>Sidebar starts fully visible. Autosave restore dialog now appears after the changelog, not over it. Hymn downloads continue in the background if you close the wizard; toast notification when done. Hymn scraping now uses og:title for reliability.</p>
        </description>
      </release>
      <release type="stable" version="0.14.7" timestamp="1780704000">
        <description>
          <p>Compact view now actually reduces row height. Fixes the CSS that was adding padding to divider rows and having no effect on service-item rows.</p>
        </description>
      </release>
      <release type="stable" version="0.14.4" timestamp="1780704000">
        <description>
          <p>Native .deb (Debian/Ubuntu) and .rpm (openSUSE/Fedora) packages. Build scripts added: build-deb.sh and build-rpm.sh.</p>
        </description>
      </release>
    </releases>
    <content_rating type="oars-1.1"/>
    <bundle type="flatpak" runtime="org.gnome.Platform/x86_64/48" sdk="org.gnome.Sdk/x86_64/48">app/io.github.calstfrancis.rubric/x86_64/master</bundle>
